# Optional API keys via environment variables.
# Copy to ".env" (git-ignored) and fill in — keeps keys out of settings.yaml entirely.
# The app auto-loads .env on startup. Existing shell env vars take precedence.
# Leave any blank to fall back to config/settings.yaml.

SERPAPI_API_KEY=
JSEARCH_API_KEY=
JSEARCH_RAPIDAPI_KEY=
TAVILY_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=
CAREERJET_AFFID=
JOOBLE_API_KEY=
# Optional notifications for the overnight pull (scripts/scheduled_pull.py)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_TO=
# Optional: résumé↔JD AI scoring (needs `pip install anthropic`)
# LLM_API_KEY=
